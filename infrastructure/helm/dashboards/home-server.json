{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "uid": "home-server",
  "title": "home-server",
  "tags": ["home-server"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "title": "Pods running",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "count(kube_pod_status_phase{namespace=\"home-server-production\",phase=\"Running\"} == 1)", "refId": "A" }
      ]
    },
    {
      "title": "App replicas — HPA current / desired / max",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        { "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"home-server-production\"}", "legendFormat": "current", "refId": "A" },
        { "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"home-server-production\"}", "legendFormat": "desired", "refId": "B" },
        { "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"home-server-production\"}", "legendFormat": "max", "refId": "C" }
      ]
    },
    {
      "title": "CPU usage vs requests (cores)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"home-server-production\",container!=\"\"}[5m])) by (pod)", "legendFormat": "{{pod}}", "refId": "A" },
        { "expr": "sum(kube_pod_container_resource_requests{namespace=\"home-server-production\",resource=\"cpu\"}) by (pod)", "legendFormat": "request {{pod}}", "refId": "B" }
      ]
    },
    {
      "title": "Memory working set vs limit",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "expr": "sum(container_memory_working_set_bytes{namespace=\"home-server-production\",container!=\"\"}) by (pod)", "legendFormat": "{{pod}}", "refId": "A" },
        { "expr": "sum(kube_pod_container_resource_limits{namespace=\"home-server-production\",resource=\"memory\"}) by (pod)", "legendFormat": "limit {{pod}}", "refId": "B" }
      ]
    },
    {
      "title": "Container restarts (1h increase)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"home-server-production\"}[1h])) by (pod)", "legendFormat": "{{pod}}", "refId": "A" }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"home-server-production\"}[5m])) by (pod)", "legendFormat": "rx {{pod}}", "refId": "A" },
        { "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"home-server-production\"}[5m])) by (pod)", "legendFormat": "tx {{pod}}", "refId": "B" }
      ]
    }
  ]
}
