<% content_for :section_subtitle do %>
  General
<% end %>

<% unless @user.otp_enabled? %>
  <div class='dashboard-item-container'>
    <strong>Two factor authentication is not enabled.</strong>
    <%= link_to('Set it up now', new_admin_two_factor_auth_path) %>
  </div>
  <div class='dashboard-item-separator'></div>
<% end %>

<div class='dashboard-item-container'>
  <h3>
    System Messages
  </h3>
  <%= render partial: 'partials/system_messages', locals: { no_messages: true } %>
</div>
<div class='dashboard-item-separator'></div>
<div class='dashboard-item-container'>
  <h3>
    Last Login
  </h3>
  <strong>Time and Date:</strong> <%= @user.last_login_time.strftime("%H:%M %d-%m-%Y") %>
  <br><br>
  <strong>IP Address:</strong> <%= @user.last_login_ip %>
</div>
<div class='dashboard-item-separator'></div>
<div class='dashboard-item-container'>
  <%= render 'admins/current_user_details' %>
</div>
<div class='dashboard-item-separator'></div>
    <div class='dashboard-item-container'>
  <h3>
    Notifications
  </h3>
  Placeholder
</div>
<div class='dashboard-item-separator'></div>
<div class='dashboard-item-container'>
  <h3>
    Analytics
  </h3>
  Placeholder
</div>
